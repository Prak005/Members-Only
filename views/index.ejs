<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <title>HomePage</title>
    </head>
    <body>
        <h1>Home</h1>
        <% if (currentUser) { %>
            <p>Welcome <%= currentUser.first_name %></p>
            <a href="/create-message">Create Message</a>
