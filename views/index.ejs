<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <title>HomePage</title>
        <link rel="stylesheet" href="/styles/style.css">
    </head>
    <body>
        <h1>Home</h1>
        <% if (success) { %>
            <p><%= success %></p>
        <% } %>
        <% if (currentUser) { %>
            <p>Welcome <%= currentUser.first_name %></p>
            <a href="/create-message">Create Message</a>
            <a href="/log-out">Logout</a>
        <% } else { %>
            <a href="/log-in">Log In</a>
            <a href="/sign-up">Sign Up</a>
        <% } %>
        <% if (currentUser && !currentUser.is_admin) { %>
            <a href="/become-admin">Admin Login</a>
        <% } %>
        <% if (currentUser && !currentUser.is_member) { %>
            <a href="/join">Become Member</a>
        <% } %>
        <h1>Messages</h1>
        <% messages.forEach(msg => { %>
            <div>
                <h3><%= msg.title %></h3>
                 <p style="white-space: pre-wrap;"><%= msg.text.trim() %></p>
                <% if (currentUser && currentUser.is_member) { %>
                    <p>By: <%= msg.first_name %> <%= msg.last_name %></p>
                    <p><%= msg.created_at %></p>
                <% } else { %>
                    <p>Anonymous</p>
                <% } %>
                <% if (currentUser && currentUser.is_admin) { %> 
                    <form action="/delete-message/<%=msg.id%>" method="POST">
                        <button type="submit">Delete</button>
                    </form>
                <% } %>
            </div>
        <% }) %>
    </body>
</html>